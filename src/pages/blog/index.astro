---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
				}
				.intro {
					 color: rgb(var(--gray));
				}
			
			.post-list {
				 display: flex;
				 flex-direction: column;
				 gap: 1.5rem;
				  margin-top: 3rem;
				  padding-left: 0;
				  list-style: none;
				  }
		    .post-card {
				 width: 100%;
				  padding: 1.75rem 2rem;
				  border: 2px solid rgb(var(--black));
				  background: rgb(var(--white));
				   box-shadow: 8px 8px 0 rgb(var(--black));
                }
			.post-link {
				 text-decoration: none;
				 }
		   .post-card h2 {
			 margin: 0;
			 font-size: 2rem;
			  line-height: 1.2;
			   }

			.post-card h2:hover {
				text-decoration: underline;
				}
				
			.post-description {
				 margin-top: 1rem;
				 margin-bottom: 0;
				 font-size: 1rem;
				 line-height: 1.6;
				 }

			.post-meta {
				margin-top: 1.25rem;
				margin-bottom: 0;
				font-size: 0.85rem; 
				color: rgb(var(--gray));
				}
				
			@media (max-width: 720px) {
				main {
				width: 100%;
				}
			
			.post-card {
				 padding: 1.25rem;
				  box-shadow: 5px 5px 0 rgb(var(--black));
				   } 
				   
			.post-card:hover {
				 transform: translate(-2px, -2px);
				  box-shadow: 7px 7px 0 rgb(var(--black));
				  }
				  
			.post-card h2 {
				 font-size: 1.5rem;
				  }
				  
			
			}
			
		</style>
	</head>
	<body>
		<Header />
	    <main>
		   <h1>Cari Y.'s Log</h1>

		    <p class="intro">
             I'm documenting my learning notes in this blog Since 2026.
		    </p>
			 <section class="post-list">
			   {
			     posts.map((post) => (
				 <article class="post-card">
				   <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}/`} class="post-link">
				    <h2>{post.data.title}</h2>
				  </a>

				  <p class="post-description">{post.data.description}</p>

				  <p class="post-meta">
				    Cathy YANG · <FormattedDate date={post.data.pubDate} />
				  </p>
				 </article>
				))
				 }
			 </section>
		</main>
		<Footer />
	</body>
</html>
